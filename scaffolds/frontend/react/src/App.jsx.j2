import { useEffect, useState } from "react";

const API = [% if has_backend %]"[[ api_base_url ]]/api"[% else %]null[% endif %];

export default function App() {
  const [items, setItems] = useState([% if has_backend %][][% else %][{ id: 1, name: "First item" }, { id: 2, name: "Second item" }][% endif %]);
  const [name, setName] = useState("");

  useEffect(() => {
    if (API) {
      fetch(`${API}/items`)
        .then((r) => r.json())
        .then(setItems);
    }
  }, []);

  async function add(event) {
    event.preventDefault();
    const value = name.trim();
    if (!value) return;
    if (API) {
      const res = await fetch(`${API}/items`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name: value }),
      });
      setItems((prev) => [...prev, await res.json()]);
    } else {
      setItems((prev) => [...prev, { id: prev.length + 1, name: value }]);
    }
    setName("");
  }

  return (
    <main[% if styling == "tailwind" %] className="max-w-xl mx-auto p-6"[% elif styling == "bootstrap" %] className="container py-4"[% endif %]>
      <h1[% if styling == "tailwind" %] className="text-2xl font-bold mb-4"[% endif %]>[[ project_name ]]</h1>
      <form onSubmit={add}[% if styling == "tailwind" %] className="flex gap-2 mb-4"[% endif %]>
        <input
          value={name}
          onChange={(e) => setName(e.target.value)}
          placeholder="New item"
[% if styling == "bootstrap" %]
          className="form-control"
[% elif styling == "tailwind" %]
          className="border rounded px-2 py-1 flex-1"
[% endif %]
        />
        <button[% if styling == "bootstrap" %] className="btn btn-primary"[% elif styling == "tailwind" %] className="bg-blue-600 text-white px-3 py-1 rounded"[% endif %]>Add</button>
      </form>
      <ul[% if styling == "bootstrap" %] className="list-group mt-3"[% endif %]>
        {items.map((it) => (
          <li key={it.id}[% if styling == "bootstrap" %] className="list-group-item"[% endif %]>{it.name}</li>
        ))}
      </ul>
    </main>
  );
}
