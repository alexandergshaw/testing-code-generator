<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>[[ project_name ]]</title>
[% if styling == "bootstrap" %]
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
[% elif styling == "tailwind" %]
    <script src="https://cdn.tailwindcss.com"></script>
[% else %]
    <link rel="stylesheet" href="styles.css" />
[% endif %]
  </head>
  <body[% if styling == "bootstrap" %] class="container py-4"[% elif styling == "tailwind" %] class="max-w-xl mx-auto p-6"[% endif %]>
    <h1[% if styling == "tailwind" %] class="text-2xl font-bold mb-4"[% endif %]>[[ project_name ]]</h1>
    <form id="add-form"[% if styling == "tailwind" %] class="flex gap-2 mb-4"[% endif %]>
      <input id="name" placeholder="New item"[% if styling == "bootstrap" %] class="form-control"[% elif styling == "tailwind" %] class="border rounded px-2 py-1 flex-1"[% endif %] />
      <button[% if styling == "bootstrap" %] class="btn btn-primary"[% elif styling == "tailwind" %] class="bg-blue-600 text-white px-3 py-1 rounded"[% endif %]>Add</button>
    </form>
    <ul id="items"[% if styling == "bootstrap" %] class="list-group mt-3"[% endif %]></ul>
    <script src="app.js"></script>
  </body>
</html>
