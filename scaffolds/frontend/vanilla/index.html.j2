<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>[[ project_name ]]</title>
[% if styling == "bootstrap" %]
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
[% elif styling == "tailwind" %]
    <script src="https://cdn.tailwindcss.com"></script>
[% else %]
    <link rel="stylesheet" href="styles.css" />
[% endif %]
  </head>
  <body[% if styling == "bootstrap" %] class="container py-4"[% elif styling == "tailwind" %] class="max-w-2xl mx-auto p-6"[% endif %]>
    <h1[% if styling == "tailwind" %] class="text-2xl font-bold mb-4"[% endif %]>[[ project_name ]]</h1>
    <div id="entities"></div>
    <script src="app.js"></script>
  </body>
</html>
