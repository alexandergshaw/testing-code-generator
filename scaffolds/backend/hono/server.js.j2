// [[ project_name ]] — Hono JSON API
const { Hono } = require("hono");
const { serve } = require("@hono/node-server");
const { cors } = require("hono/cors");
const repo = require("./repo");
[% if auth == "jwt" %]
const crypto = require("crypto");
[% endif %]

const app = new Hono();
app.use("/*", cors());

app.get("/api/health", (c) => c.json({ status: "ok" }));
[% if auth == "jwt" %]

const JWT_SECRET = "dev-secret-change-me"; // override via env in production

function b64url(value) {
  return Buffer.from(value).toString("base64url");
}

function makeToken(sub) {
  const header = b64url(JSON.stringify({ alg: "HS256", typ: "JWT" }));
  const payload = b64url(JSON.stringify({ sub, exp: Math.floor(Date.now() / 1000) + 3600 }));
  const sig = crypto.createHmac("sha256", JWT_SECRET).update(`${header}.${payload}`).digest("base64url");
  return `${header}.${payload}.${sig}`;
}

function verifyToken(token) {
  const parts = (token || "").split(".");
  if (parts.length !== 3) return null;
  const [header, payload, sig] = parts;
  const expected = crypto.createHmac("sha256", JWT_SECRET).update(`${header}.${payload}`).digest("base64url");
  if (sig !== expected) return null;
  let claims;
  try {
    claims = JSON.parse(Buffer.from(payload, "base64url").toString());
  } catch {
    return null;
  }
  if ((claims.exp || 0) < Math.floor(Date.now() / 1000)) return null;
  return claims;
}

app.post("/api/login", async (c) => {
  const body = await c.req.json().catch(() => ({}));
  const username = (body.username ? String(body.username) : "").trim();
  if (!username) return c.json({ error: "username required" }, 400);
  return c.json({ token: makeToken(username) });
});

app.get("/api/me", (c) => {
  const header = c.req.header("Authorization") || "";
  const token = header.startsWith("Bearer ") ? header.slice(7) : "";
  const claims = verifyToken(token);
  if (!claims) return c.json({ error: "unauthorized" }, 401);
  return c.json(claims);
});
[% endif %]
[% for entity in entities %]

// ---- [[ entity.class_name ]] ----
app.get("[[ entity.route ]]", async (c) => c.json(await repo.list("[[ entity.plural ]]")));

app.post("[[ entity.route ]]", async (c) => {
  const body = await c.req.json().catch(() => ({}));
  const item = await repo.create("[[ entity.plural ]]", body);
  return c.json(item, 201);
});

app.get("[[ entity.route ]]/:id", async (c) => {
  const item = await repo.get("[[ entity.plural ]]", c.req.param("id"));
  if (!item) return c.json({ error: "not found" }, 404);
  return c.json(item);
});

app.put("[[ entity.route ]]/:id", async (c) => {
  const body = await c.req.json().catch(() => ({}));
  const item = await repo.update("[[ entity.plural ]]", c.req.param("id"), body);
  if (!item) return c.json({ error: "not found" }, 404);
  return c.json(item);
});

app.delete("[[ entity.route ]]/:id", async (c) => {
  const ok = await repo.remove("[[ entity.plural ]]", c.req.param("id"));
  if (!ok) return c.json({ error: "not found" }, 404);
  return c.body(null, 204);
});
[% endfor %]

const PORT = [[ backend_port ]];
serve({ fetch: app.fetch, port: PORT }, () => {
  console.log(`API on http://localhost:${PORT}`);
});
