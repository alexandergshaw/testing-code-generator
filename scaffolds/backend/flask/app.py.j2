[% for entity in entities %]
@strawberry.type
class [[ entity.class_name ]]GQL:
    id: int
[% for f in entity.fields %]
    [[ f.name ]]: [[ f.pydantic ]]
[% endfor %]


[% endfor %]
@strawberry.type
class Query:
[% for entity in entities %]
    @strawberry.field
    def [[ entity.plural ]](self) -> list[ [[ entity.class_name ]]GQL ]:
        return [ [[ entity.class_name ]]GQL(**row) for row in _[[ entity.plural ]] ]

[% endfor %]

@strawberry.type
class Mutation:
[% for entity in entities %]
    @strawberry.mutation
    def create_[[ entity.var ]](self[% for f in entity.fields | sort(attribute="required", reverse=True) %], [[ f.name ]]: [[ f.pydantic ]][% endfor %]) -> [[ entity.class_name ]]GQL:
        global _[[ entity.var ]]_seq
        _[[ entity.var ]]_seq += 1
        row = {"id": _[[ entity.var ]]_seq[% for f in entity.fields %], "[[ f.name ]]": [[ f.name ]][% endfor %]}
        _[[ entity.plural ]].append(row)
        return [[ entity.class_name ]]GQL(**row)

[% endfor %]

app.add_url_rule(
    "/graphql",
    view_func=GraphQLView.as_view(
        "graphql_view", schema=strawberry.Schema(query=Query, mutation=Mutation)
    ),
)

