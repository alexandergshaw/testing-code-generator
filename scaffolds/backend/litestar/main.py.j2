import base64
import hashlib
import hmac
import json
import time
[% endif %]

from litestar import Litestar, Request, delete, get, post, put
from litestar.config.cors import CORSConfig
from litestar.exceptions import NotFoundException
[% if has_db %]

from db import SessionLocal, init_db, [[ entities | map(attribute='class_name') | join(", ") ]]
[% endif %]
[% if not has_db %]

# In-memory stores (no database selected).
[% for entity in entities %]
_[[ entity.plural ]] = []
_[[ entity.var ]]_seq = 0
[% endfor %]
[% endif %]
[% if has_db %]

[% for entity in entities %]
def _dump_[[ entity.var ]](obj):
    return {"id": obj.id[% for f in entity.fields %], "[[ f.name ]]": obj.[[ f.name ]][% endfor %]}


[% endfor %]
[% endif %]

@get("/api/health", sync_to_thread=False)
def health() -> dict:
    return {"status": "ok"}

[% if auth == "jwt" %]
_JWT_SECRET = "dev-secret-change-me"  # override via env in production


def _b64url(data):
    return base64.urlsafe_b64encode(data).decode().rstrip("=")


def _make_token(sub):
    header = _b64url(json.dumps({"alg": "HS256", "typ": "JWT"}).encode())
    payload = _b64url(json.dumps({"sub": sub, "exp": int(time.time()) + 3600}).encode())
    signature = _b64url(
        hmac.new(_JWT_SECRET.encode(), f"{header}.{payload}".encode(), hashlib.sha256).digest()
    )
    return f"{header}.{payload}.{signature}"


def _verify_token(token):
    try:
        header, payload, signature = token.split(".")
    except ValueError:
        return None
    expected = _b64url(
        hmac.new(_JWT_SECRET.encode(), f"{header}.{payload}".encode(), hashlib.sha256).digest()
    )
    if not hmac.compare_digest(signature, expected):
        return None
    claims = json.loads(base64.urlsafe_b64decode(payload + "=="))
    if claims.get("exp", 0) < int(time.time()):
        return None
    return claims


@post("/api/login", sync_to_thread=False)
def login(data: dict) -> dict:
    username = (data.get("username") or "").strip()
    if not username:
        from litestar.exceptions import ClientException

        raise ClientException(detail="username required")
    return {"token": _make_token(username)}


@get("/api/me", sync_to_thread=False)
def me(request: Request) -> dict:
    from litestar.exceptions import NotAuthorizedException

    header = request.headers.get("authorization", "")
    token = header[7:] if header.startswith("Bearer ") else ""
    claims = _verify_token(token)
    if claims is None:
        raise NotAuthorizedException(detail="unauthorized")
    return claims

[% endif %]
[% for entity in entities %]

# ---- [[ entity.class_name ]] ----
@get("[[ entity.route ]]", sync_to_thread=False)
def list_[[ entity.plural ]]() -> list:
[% if has_db %]
    with SessionLocal() as session:
        rows = session.query([[ entity.class_name ]]).order_by([[ entity.class_name ]].id).all()
        return [_dump_[[ entity.var ]](row) for row in rows]
[% else %]
    return _[[ entity.plural ]]
[% endif %]


@post("[[ entity.route ]]", status_code=201, sync_to_thread=False)
def create_[[ entity.var ]](data: dict) -> dict:
[% if has_db %]
    obj = [[ entity.class_name ]]([% for f in entity.fields %][[ f.name ]]=data.get("[[ f.name ]]")[% if not loop.last %], [% endif %][% endfor %])
    with SessionLocal() as session:
        session.add(obj)
        session.commit()
        return _dump_[[ entity.var ]](obj)
[% else %]
    global _[[ entity.var ]]_seq
    _[[ entity.var ]]_seq += 1
    obj = {"id": _[[ entity.var ]]_seq[% for f in entity.fields %], "[[ f.name ]]": data.get("[[ f.name ]]")[% endfor %]}
    _[[ entity.plural ]].append(obj)
    return obj
[% endif %]


@get("[[ entity.route ]]/{obj_id:int}", sync_to_thread=False)
def get_[[ entity.var ]](obj_id: int) -> dict:
[% if has_db %]
    with SessionLocal() as session:
        obj = session.get([[ entity.class_name ]], obj_id)
        if obj is None:
            raise NotFoundException(detail="not found")
        return _dump_[[ entity.var ]](obj)
[% else %]
    obj = next((x for x in _[[ entity.plural ]] if x["id"] == obj_id), None)
    if obj is None:
        raise NotFoundException(detail="not found")
    return obj
[% endif %]


@put("[[ entity.route ]]/{obj_id:int}", sync_to_thread=False)
def update_[[ entity.var ]](obj_id: int, data: dict) -> dict:
[% if has_db %]
    with SessionLocal() as session:
        obj = session.get([[ entity.class_name ]], obj_id)
        if obj is None:
            raise NotFoundException(detail="not found")
        for key, value in data.items():
            if key != "id" and hasattr(obj, key):
                setattr(obj, key, value)
        session.commit()
        return _dump_[[ entity.var ]](obj)
[% else %]
    obj = next((x for x in _[[ entity.plural ]] if x["id"] == obj_id), None)
    if obj is None:
        raise NotFoundException(detail="not found")
    for key, value in data.items():
        if key != "id":
            obj[key] = value
    return obj
[% endif %]


@delete("[[ entity.route ]]/{obj_id:int}", sync_to_thread=False)
def delete_[[ entity.var ]](obj_id: int) -> None:
[% if has_db %]
    with SessionLocal() as session:
        obj = session.get([[ entity.class_name ]], obj_id)
        if obj is None:
            raise NotFoundException(detail="not found")
        session.delete(obj)
        session.commit()
[% else %]
    global _[[ entity.plural ]]
    before = len(_[[ entity.plural ]])
    _[[ entity.plural ]] = [x for x in _[[ entity.plural ]] if x["id"] != obj_id]
    if len(_[[ entity.plural ]]) == before:
        raise NotFoundException(detail="not found")
[% endif %]
[% endfor %]

app = Litestar(
    route_handlers=[
        health,
[% if auth == "jwt" %]
        login,
        me,
[% endif %]
[% for entity in entities %]
        list_[[ entity.plural ]],
        create_[[ entity.var ]],
        get_[[ entity.var ]],
        update_[[ entity.var ]],
        delete_[[ entity.var ]],
[% endfor %]
    ],
    cors_config=CORSConfig(allow_origins=["*"]),
[% if has_db %]
    on_startup=[lambda app: init_db()],
[% endif %]
)
