[% if has_backend %]
[% if python_backend %]
FROM python:3.12-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY . .
EXPOSE [[ backend_port ]]
[% if backend == "flask" %]
CMD ["python", "app.py"]
[% else %]
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "[[ backend_port ]]"]
[% endif %]
[% else %]
FROM node:20-slim
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
EXPOSE [[ backend_port ]]
CMD ["node", "server.js"]
[% endif %]
[% endif %]
