name: CI
on:
  push:
  pull_request:

jobs:
[% if python_backend %]
  backend:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: [[ backend_dir or "." ]]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - run: pip install -r requirements.txt
      - run: python -m compileall .
[% if addon_tests %]
      - run: pytest
[% endif %]
[% endif %]
[% if node_backend %]
  backend:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: [[ backend_dir or "." ]]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "20"
      - run: npm install
      - run: node --check server.js
[% endif %]
[% if spa %]
  frontend:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: [[ frontend_dir or "." ]]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "20"
      - run: npm install
      - run: npm run build
[% endif %]
[% if not python_backend and not node_backend and not spa %]
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - run: echo "Static site — nothing to build."
[% endif %]
