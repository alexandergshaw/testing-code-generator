// MySQL connection (mysql2 pool) + table creation (no migration step needed).
const mysql = require("mysql2/promise");
const { drizzle } = require("drizzle-orm/mysql2");

const pool = mysql.createPool(process.env.DATABASE_URL || "[[ db_url ]]");
const db = drizzle(pool);

// Create tables on first run (and seed the demo rows). `ready` resolves once the
// schema exists; the repo awaits it before every query, so the async setup never
// races the first request and the route handlers stay untouched.
const ready = (async () => {
[% for entity in entities %]
  await pool.query(`
    CREATE TABLE IF NOT EXISTS [[ entity.table ]] (
      id INT AUTO_INCREMENT PRIMARY KEY[% for f in entity.fields %],
      [[ f.name ]] [% if f.type == "boolean" %]BOOLEAN[% elif f.type == "integer" %]INT[% elif f.type == "float" %]DOUBLE[% else %]TEXT[% endif %][% endfor %]
    )
  `);
[% endfor %]
[% if is_default_schema %]
  const [rows] = await pool.query("SELECT COUNT(*) AS n FROM items");
  if (rows[0].n === 0) {
    await pool.query("INSERT INTO items (name) VALUES ('First item'), ('Second item')");
  }
[% endif %]
})();

module.exports = { db, ready };
