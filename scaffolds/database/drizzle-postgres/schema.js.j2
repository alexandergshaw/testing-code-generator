// Drizzle ORM schema (PostgreSQL) — one table per entity.
const { pgTable, serial, integer, doublePrecision, boolean, text } = require("drizzle-orm/pg-core");

[% for entity in entities %]
const [[ entity.var ]] = pgTable("[[ entity.table ]]", {
  id: serial("id").primaryKey(),
[% for f in entity.fields %]
  [[ f.name ]]: [% if f.type == "boolean" %]boolean("[[ f.name ]]")[% elif f.type == "integer" %]integer("[[ f.name ]]")[% elif f.type == "float" %]doublePrecision("[[ f.name ]]")[% else %]text("[[ f.name ]]")[% endif %],
[% endfor %]
});
[% endfor %]

// table lookup + column allow-lists, keyed by the API plural.
const tables = {
[% for entity in entities %]
  [[ entity.plural ]]: [[ entity.var ]],
[% endfor %]
};

const columns = {
[% for entity in entities %]
  [[ entity.plural ]]: [ [% for f in entity.fields %]"[[ f.name ]]"[% if not loop.last %], [% endif %][% endfor %]],
[% endfor %]
};

module.exports = { tables, columns };
