// Mongoose models — one per entity. Mongo is schemaless, but a schema gives us
// typed fields and keeps writes to the known columns.
const mongoose = require("mongoose");

[% for entity in entities %]
const [[ entity.var ]] = mongoose.model("[[ entity.class_name ]]", new mongoose.Schema({
[% for f in entity.fields %]
  [[ f.name ]]: [% if f.type == "boolean" %]Boolean[% elif f.type == "integer" or f.type == "float" %]Number[% else %]String[% endif %],
[% endfor %]
}));
[% endfor %]

// model lookup + column allow-lists, keyed by the API plural.
const models = {
[% for entity in entities %]
  [[ entity.plural ]]: [[ entity.var ]],
[% endfor %]
};

const columns = {
[% for entity in entities %]
  [[ entity.plural ]]: [ [% for f in entity.fields %]"[[ f.name ]]"[% if not loop.last %], [% endif %][% endfor %]],
[% endfor %]
};

module.exports = { models, columns };
